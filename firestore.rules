rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /trips/{tripId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.travelerId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.travelerId;
    }

    match /requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.requesterId;
      allow update: if request.auth != null && (
        // Only the traveler can make general updates
        request.auth.uid == resource.data.travelerId ||
        // The requester can ONLY update the request if they are changing the status to 'cancelled'
        (request.auth.uid == resource.data.requesterId && request.resource.data.status == 'cancelled')
      );
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /conversations/{convId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    match /notifications/{uid}/items/{itemId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    match /open_requests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.requesterId;
      allow update: if request.auth != null && (
        // Owner can update (cancel, etc.)
        request.auth.uid == resource.data.requesterId ||
        // Any authenticated user can increment offerCount
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['offerCount', 'status']))
      );
    }

    match /offers/{offerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.travelerId;
      allow update: if request.auth != null;
    }
  }
}
